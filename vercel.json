{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/start", "destination": "/api" },
    { "source": "/events", "destination": "/api" },
    { "source": "/stream/(.*)", "destination": "/api" },
    { "source": "/thread/(.*)", "destination": "/api" },
    { "source": "/followup", "destination": "/api" }
  ]
}
